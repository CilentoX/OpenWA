# =============================================================================
# OpenWA - Environment Configuration
# =============================================================================
# Copy this file to .env and customize as needed.
# Optimized for Coolify deployment with external Traefik.

# =============================================================================
# CORE SETTINGS
# =============================================================================
NODE_ENV=production
API_PORT=2785
LOG_LEVEL=info                      # error | warn | info | debug

# =============================================================================
# DOMAIN / ROUTING (used by Traefik labels in docker-compose.yml)
# =============================================================================
DOMAIN=yourdomain.com
API_HOST=api-openwa.yourdomain.com
DASHBOARD_HOST=openwa.yourdomain.com

# Public URLs (used by the app for links, CORS, startup banner)
BASE_URL=https://api-openwa.yourdomain.com
DASHBOARD_URL=https://openwa.yourdomain.com

# CORS Configuration (comma-separated origins, or * for all)
CORS_ORIGINS=https://openwa.yourdomain.com

# =============================================================================
# ENGINE CONFIGURATION
# =============================================================================
# Which WhatsApp engine to use (plugin-based)
# Options: whatsapp-web.js, baileys (future)
ENGINE_TYPE=whatsapp-web.js

# Engine-specific settings
SESSION_DATA_PATH=./data/sessions
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu

# =============================================================================
# DATABASE
# =============================================================================
# Options: sqlite, postgres
DATABASE_TYPE=postgres

# PostgreSQL settings (container "postgres" is always started)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=openwa
DATABASE_USERNAME=openwa
DATABASE_PASSWORD=your-secure-password
DATABASE_SYNCHRONIZE=false          # WARNING: Set false in production!
DATABASE_LOGGING=false

# =============================================================================
# REDIS / QUEUE (Phase 2)
# =============================================================================
REDIS_ENABLED=false                 # Enable Redis for queue and caching

# Redis settings (only used if redis profile is active)
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=

# =============================================================================
# STORAGE
# =============================================================================
# Options: local, s3
STORAGE_TYPE=local

# Local storage path (if STORAGE_TYPE=local)
STORAGE_LOCAL_PATH=./data/media

# S3/MinIO settings (if STORAGE_TYPE=s3, use minio profile)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=openwa
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# =============================================================================
# WEBHOOK
# =============================================================================
WEBHOOK_TIMEOUT=10000               # Timeout in milliseconds
WEBHOOK_MAX_RETRIES=3               # Number of retry attempts
WEBHOOK_RETRY_DELAY=5000            # Delay between retries in ms

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_TTL=60                   # Time window in seconds
RATE_LIMIT_MAX=100                  # Max requests per window

# =============================================================================
# PLUGINS
# =============================================================================
PLUGINS_ENABLED=true                # Enable plugin system
PLUGINS_DIR=./data/plugins          # Plugin directory

# =============================================================================
# SECURITY
# =============================================================================
# Master API key (leave empty to disable, or set to secure value)
API_MASTER_KEY=

# =============================================================================
# DEVELOPER SETTINGS
# =============================================================================
ENABLE_SWAGGER=true                 # Enable API documentation at /api/docs
